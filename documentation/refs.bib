@inbook{birefringence,
author = {Saleh, B.E.A. and Teich, M.C.},
publisher = {John Wiley and Sons, Ltd},
isbn = {9780471213741},
title = {Polarization and Crystal Optics},
booktitle = {Fundamentals of Photonics},
chapter = {6},
pages = {193-237},
doi = {https://doi.org/10.1002/0471213748.ch6},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/0471213748.ch6},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/0471213748.ch6},
year = {1991},
keywords = {polarization, light, reflection, refraction, anisotropic media, optics, optimal activity, Faraday effect, liquid crystals, devices, problems, exercises},
abstract = {Summary Polarization plays an important role in the interaction of light with matter attested to by the following examples: The amount of light reflected at the boundary between two materials depends the polarization of the incident wave. The amount of light absorbed by certain materials is polarization dependent. Light scattering from matter is generally polarization sensitive. The refractive index of anisotropic materials depends on the polarization. Waves with different polarizations therefore travel at different velocities and undergo different phase shifts, so that the polarization ellipse is modified as the wave advances. This property is used in the design of many optical devices. So-called optically active materials have the natural ability to rotate the polarization plane of linearly polarized light. In the presence of a magnetic field, most materials rotate the polarization. When arranged in certain configurations, liquid crystals also act as polarization rotators. This chapter is devoted to elementary polarization phenomena and a number of their applications. Elliptically polarized light is introduced using a matrix formalism that is convenient for describing polarization devices. The effect of polarization on the reflection and refraction of light at the boundaries between dielectric media is described. The propagation of light through anisotropic media (crystals), optically active media, and liquid crystals are the subjects of later sections respectively. Finally, basic polarization devices (polarizers, retarders, and rotators) are discussed.}
}

